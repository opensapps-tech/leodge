<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#1a1a2e">

    <!-- Header with App Name and Total Value -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/notification_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEODGE"
            android:textColor="#00d4aa"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/notification_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="£--.--"
            android:textColor="#00d4aa"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Cash and Invested Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash: "
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/notification_cash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="£--.--"
                android:textColor="#ffffff"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Invested: "
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/notification_invested"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="£--.--"
                android:textColor="#ffffff"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Last Updated -->
    <TextView
        android:id="@+id/notification_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Updated: --"
        android:textColor="#666666"
        android:textSize="10sp" />

</LinearLayout>
